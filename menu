# Catppuccin Mocha — Fluxbox Menu
# Place at ~/.fluxbox/menu
# Regenerate anytime with: fluxbox-generate_menu (then re-apply theme edits)

[begin] (  Mocha )
  [exec]   (Terminal)         {xterm -bg '#1e1e2e' -fg '#cdd6f4' -fn 'monospace-10'}
  [exec]   (File Manager)     {thunar}
  [exec]   (Browser)          {firefox}
  [exec]   (Text Editor)      {mousepad}

  [submenu] (Development)
    [exec] (VSCodium)         {codium}
    [exec] (Neovim)           {xterm -e nvim}
    [exec] (Gitk)             {gitk}
  [end]

  [submenu] (Graphics)
    [exec] (GIMP)             {gimp}
    [exec] (Inkscape)         {inkscape}
    [exec] (Feh Wallpaper…)   {feh --bg-fill ~/.wallpapers/catppuccin-mocha.png}
  [end]

  [submenu] (Internet)
    [exec] (Thunderbird)      {thunderbird}
    [exec] (Transmission)     {transmission-gtk}
  [end]

  [submenu] (Media)
    [exec] (MPV)              {mpv}
    [exec] (VLC)              {vlc}
    [exec] (Pavucontrol)      {pavucontrol}
  [end]

  [submenu] (System)
    [exec] (htop)             {xterm -e htop}
    [exec] (Polybar reload)   {pkill polybar; sleep 0.5; polybar catppuccin &}
    [exec] (Fluxbox reload)   {fluxbox-remote restart}
    [exec] (Lock screen)      {xlock -mode blank}
    [exec] (Screenshot)       {scrot ~/Pictures/screenshot-%Y%m%d-%H%M%S.png}
  [end]

  [submenu] (Fluxbox)
    [config]  (Configuration)
    [reconfig](Reconfigure)
    [restart] (Restart)
    [submenu] (Styles)
      [stylesdir] (~/.fluxbox/styles)
    [end]
    [submenu] (Workspaces)
      [workspaces] (Workspaces)
    [end]
  [end]

  [separator]
  [exit]   (Quit)
[end]
